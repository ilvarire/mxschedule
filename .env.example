APP_NAME=MXSchedule
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# Email domain restriction for self-registration (e.g. @university.edu)
ALLOWED_EMAIL_DOMAIN=@your-university.edu

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use 'warning' in production to avoid PII leaking into logs
LOG_LEVEL=warning

# ── Database ──────────────────────────────────────────────────────────────
# SQLite is for local development only. Use MySQL or PostgreSQL in production.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mxschedule
DB_USERNAME=mxschedule_user
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Encrypt session data in production
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting / Queue / Cache ──────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Use 'redis' for high-throughput production environments
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# ── Redis (optional, recommended for production queues) ───────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change MAIL_MAILER from 'log' to 'smtp' or your mail driver.
# Students will NOT receive schedule notifications if this is left as 'log'.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS / S3 (optional, for cloud PDF storage) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
